# Secrets for the Supabase Edge Functions (server-side — NOT shipped to the browser).
#
# Copy this to `supabase/.env`, fill it in, then push it to Supabase with:
#
#     supabase secrets set --env-file ./supabase/.env
#
# This keeps your keys in a local .env file (git-ignored) instead of clicking
# around the dashboard. They get uploaded to Supabase's encrypted secret store
# so the deployed edge functions can read them at runtime.
#
# For LOCAL function testing (`supabase functions serve --env-file ./supabase/.env`)
# the same file is read directly — no upload needed.

# One key per provider — each persona slot uses a different provider:
#   1 GPT-OSS 120B  → OpenRouter  (openai/gpt-oss-120b:free)
#   2 Llama 3.3 70B → Groq        (llama-3.3-70b-versatile)
#   3 Mistral Small → Mistral     (mistral-small-latest)
#   4 Gemini Flash  → Gemini      (gemini-3.1-flash-lite-preview)
#   5 Arbi   → Gemini      (gemini-3.1-flash-lite-preview)   ← the judge
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Optional) override a slot's provider/model without redeploying code.
# Provider must be one of: openrouter | groq | mistral | gemini
# LLM_PROVIDER_1=openrouter
# LLM_MODEL_1=openai/gpt-oss-120b:free
# LLM_PROVIDER_2=groq
# LLM_MODEL_2=llama-3.3-70b-versatile
# LLM_PROVIDER_3=mistral
# LLM_MODEL_3=mistral-small-latest
# LLM_PROVIDER_4=gemini
# LLM_MODEL_4=gemini-3.1-flash-lite-preview
# LLM_PROVIDER_5=gemini
# LLM_MODEL_5=gemini-3.1-flash-lite-preview

# ---------------------------------------------------------------------------
# Daily reminder email (Zoho ZeptoMail) — used by the `send-daily-reminder`
# Edge Function to email signed-up players "today's question is live".
#
#   ZEPTOMAIL_TOKEN     ZeptoMail "Send Mail Token" (Mail Agents → your agent →
#                       Setup Info / SMTP & API → Send Mail Token). Sent as the
#                       Authorization header value after `Zoho-enczapikey `.
#   EMAIL_FROM_ADDRESS  A sender on a domain you've VERIFIED in ZeptoMail.
#   EMAIL_FROM_NAME     From display name (default "Quorum").
#   ZEPTOMAIL_API_URL   (optional) override the endpoint for EU/other data
#                       centres, e.g. https://api.zeptomail.eu/v1.1/email
#   QUORUM_SITE_URL     (optional) play-link target (default quorumdaily.com).
# ---------------------------------------------------------------------------
ZEPTOMAIL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM_ADDRESS=noreply@quorumdaily.com
EMAIL_FROM_NAME=Quorum
# ZEPTOMAIL_API_URL=https://api.zeptomail.com/v1.1/email
# QUORUM_SITE_URL=https://quorumdaily.com
