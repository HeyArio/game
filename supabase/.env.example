# Secrets for the Supabase Edge Functions (server-side — NOT shipped to the browser).
#
# Copy this to `supabase/.env`, fill it in, then push it to Supabase with:
#
#     supabase secrets set --env-file ./supabase/.env
#
# This keeps your keys in a local .env file (git-ignored) instead of clicking
# around the dashboard. They get uploaded to Supabase's encrypted secret store
# so the deployed edge functions can read them at runtime.
#
# For LOCAL function testing (`supabase functions serve --env-file ./supabase/.env`)
# the same file is read directly — no upload needed.

# One build.nvidia.com key works for all 5 models:
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Optional) only if your 5 models need separate keys — these override the shared one:
# NVIDIA_API_KEY_1=
# NVIDIA_API_KEY_2=
# NVIDIA_API_KEY_3=
# NVIDIA_API_KEY_4=
# NVIDIA_API_KEY_5=

# Model IDs are baked into the function as defaults — only set these to override:
# NVIDIA_MODEL_1=nvidia/nemotron-3-ultra-550b-a55b
# NVIDIA_MODEL_2=minimaxai/minimax-m3
# NVIDIA_MODEL_3=mistralai/mistral-medium-3.5-128b
# NVIDIA_MODEL_4=deepseek-ai/deepseek-v4-pro
# NVIDIA_MODEL_5=google/gemma-4-31b-it
