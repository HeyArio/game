# Copy this file to `.env` and fill in values from your Supabase project
# (Supabase dashboard → Project Settings → API). These are public anon keys —
# safe to expose in the client build. Row Level Security protects the data.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ---------------------------------------------------------------------------
# TESTING ONLY — client-side NVIDIA case generation.
#
# If VITE_NVIDIA_API_KEY is set, the app generates the daily case directly in
# the browser (calling the 5 NVIDIA models) and scores locally — no edge
# functions or DB writes needed. Handy for local testing of the full game loop.
#
# ⚠️  This exposes your key in the browser and only works under `npm run dev`
#     (it relies on the Vite dev proxy). Leave it BLANK for any real deployment;
#     production uses the server-side edge function instead.
# ---------------------------------------------------------------------------
VITE_NVIDIA_API_KEY=

# Model assignment (defaults shown — only set these to override a slot):
#   1 ASTRA  → minimaxai/minimax-m3
#   2 BOREAS → mistralai/mistral-medium-3.5-128b
#   3 CIRRUS → deepseek-ai/deepseek-v4-pro
#   4 DELPHI → google/gemma-4-31b-it
#   5 Arbi   → nvidia/nemotron-3-ultra-550b-a55b   (the judge — most capable model)
VITE_NVIDIA_MODEL_1=minimaxai/minimax-m3
VITE_NVIDIA_MODEL_2=mistralai/mistral-medium-3.5-128b
VITE_NVIDIA_MODEL_3=deepseek-ai/deepseek-v4-pro
VITE_NVIDIA_MODEL_4=google/gemma-4-31b-it
VITE_NVIDIA_MODEL_5=nvidia/nemotron-3-ultra-550b-a55b
