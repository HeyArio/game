# Copy this file to `.env` and fill in values from your Supabase project
# (Supabase dashboard → Project Settings → API). These are public anon keys —
# safe to expose in the client build. Row Level Security protects the data.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ---------------------------------------------------------------------------
# TESTING ONLY — client-side case generation.
#
# If ANY provider key below is set, the app generates the daily case directly
# in the browser (calling the 5 LLM providers) and scores locally — no edge
# functions or DB writes needed. Handy for local testing of the full game loop.
#
# Each persona slot is backed by a different provider:
#   1 ASTRA  → OpenRouter  (openrouter/free)
#   2 BOREAS → Groq        (llama-3.1-70b-versatile)
#   3 CIRRUS → Mistral     (mistral-small-latest)
#   4 DELPHI → Z.ai        (glm-4.7)
#   5 Arbi   → Gemini      (gemini-3.1-flash-lite-preview)   ← the judge
#
# ⚠️  This exposes your keys in the browser and only works under `npm run dev`
#     (it relies on the Vite dev proxies). Leave these BLANK for any real
#     deployment; production uses the server-side edge function instead.
# ---------------------------------------------------------------------------
VITE_OPENROUTER_API_KEY=
VITE_GROQ_API_KEY=
VITE_MISTRAL_API_KEY=
VITE_GEMINI_API_KEY=
VITE_ZAI_API_KEY=

# (Optional) override a slot's provider/model without touching code.
# Provider must be one of: openrouter | groq | mistral | zai | gemini
# VITE_LLM_PROVIDER_1=openrouter
# VITE_LLM_MODEL_1=openrouter/free
# VITE_LLM_PROVIDER_2=groq
# VITE_LLM_MODEL_2=llama-3.1-70b-versatile
# VITE_LLM_PROVIDER_3=mistral
# VITE_LLM_MODEL_3=mistral-small-latest
# VITE_LLM_PROVIDER_4=zai
# VITE_LLM_MODEL_4=glm-4.7
# VITE_LLM_PROVIDER_5=gemini
# VITE_LLM_MODEL_5=gemini-3.1-flash-lite-preview
